# ══════════════════════════════════════════════════════════════════════════════
#  Terraria Hub — Environment Configuration
#  Copy this file to .env and fill in your values before running.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Panel ─────────────────────────────────────────────────────────────────────

# Port the web panel listens on inside the container (and mapped to the host).
PANEL_PORT=3001

# Secret used to sign JWTs. Generate with: openssl rand -hex 32
# REQUIRED — the server refuses to start if this is not set.
JWT_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────────

# Email address for the bootstrap admin account.
# Created automatically on first start if no user with this email exists.
# REQUIRED.
ADMIN_EMAIL=

# Temporary password set on the admin account at first start.
# Change it immediately after your first login.
# REQUIRED.
ADMIN_TEMP_PASS=

# IP address or hostname of the host machine.
# Used in email verification and password reset links.
# Example: 192.168.1.100 or terraria.example.com
# REQUIRED.
HOST_IP=

# ── Paths ─────────────────────────────────────────────────────────────────────

# Path to world data INSIDE the panel container. Do not change unless you
# also update the volume mount in docker-compose.yml.
WORLDS_DIR=/worlds

# Path to world data on the HOST machine. Docker uses this to bind-mount
# world directories into each per-world game container.
# Example: /home/youruser/docker/terraria-hub/worlds
# REQUIRED.
HOST_WORLDS_DIR=

# ── Game containers ───────────────────────────────────────────────────────────

# tModLoader Docker image used for each world container.
TMOD_IMAGE=jacobsmile/tmodloader1.4:latest

# Game port allocation range. Each world gets a unique port from this range.
# Make sure these ports are open in your firewall if not using playit.gg.
PORT_BASE=7777
PORT_MAX=7900

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Required for email verification and password reset.
# Any STARTTLS SMTP provider works. Common options:
#   Zoho Mail:   smtppro.zoho.com:587
#   Gmail:       smtp.gmail.com:587       (requires an App Password)
#   Brevo:       smtp-relay.brevo.com:587 (300 emails/day free)
#   Outlook:     smtp-mail.outlook.com:587
#   Mailtrap:    sandbox.smtp.mailtrap.io:587 (dev/testing only)

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From address shown in outgoing emails. Defaults to SMTP_USER if blank.
SMTP_FROM=
